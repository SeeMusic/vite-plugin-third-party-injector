{
  "name": "@kanjianmusic/vite-plugin-third-party-injector",
  "version": "8.0.1",
  "type": "module",
  "description": "Vite plugin for injecting third-party scripts into HTML files, such as gtag, gtm, etc.",
  "scripts": {
    "build": "tsup"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "keywords": [
    "vite-plugin",
    "vite",
    "analytics",
    "gtag",
    "gtm",
    "clarity",
    "facebook-pixel"
  ],
  "author": "cuiguojie@kanjian.com",
  "license": "MIT",
  "homepage": "https://github.com/SeeMusic/vite-plugin-third-party-injector",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeeMusic/vite-plugin-third-party-injector.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
