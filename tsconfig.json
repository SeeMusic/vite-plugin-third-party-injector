{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "types": ["node"],
    "noUnusedLocals": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ESNext"],
    "sourceMap": false,
    "noEmitOnError": true,
    "noImplicitAny": false
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
